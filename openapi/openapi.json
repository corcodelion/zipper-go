 is active","example":true},"eventTypes":{"type":"array","description":"Subscribed event types","example":["DELIVERY_STATUS_CHANGED"],"items":{"type":"string"}},"callbackConfig":{"$ref":"#/components/schemas/CallbackConfigDTO","description":"Callback configuration (retry policy)"},"createdAt":{"type":"string","format":"date-time","description":"Creation timestamp"},"updatedAt":{"type":"string","format":"date-time","description":"Last update timestamp"},"clientSecret":{"type":"string","description":"HMAC secret for verifying webhook signatures (only returned on creation)"}}},"CreateWebhookRequest":{"type":"object","description":"Request to create or update a webhook subscription","properties":{"callbackUrl":{"type":"string","description":"HTTPS URL that will receive webhook events","example":"https://example.com/webhooks","maxLength":2048,"minLength":0},"enabled":{"type":"boolean","description":"Whether the webhook is active","example":true},"eventTypes":{"type":"array","description":"Event types to subscribe to","enum":["status_changed","test_event"],"example":["status_changed","test_event"],"items":{"type":"string"},"maxItems":2147483647,"minItems":1},"callbackConfig":{"$ref":"#/components/schemas/CallbackConfigDTO","description":"Optional callback configuration (retry policy)"},"webhookSecret":{"type":"string","description":"Optional webhook secret. If not provided, one will be auto-generated.","example":"whsec-my-custom-secret-key","maxLength":255,"minLength":0}},"required":["callbackUrl","eventTypes"]},"TestWebhookRequest":{"type":"object","description":"Optional request body for sending a test webhook event","properties":{"testField":{"type":"string","description":"Custom payload for the test event; if omitted, a default value is used","example":"ping"}}},"AddressDTO":{"type":"object","description":"Structured address information","properties":{"fullAddress":{"type":"string","description":"Full formatted address string. Auto-generated from individual fields if 